{
  "expo": {
    "name": "Reading Trainer",
    "slug": "reading-trainer-mobile",
    "version": "0.1.0",
    "orientation": "default",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1f2430"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.readingtrainer.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3F76D6"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-asset"
    ]
  }
}
